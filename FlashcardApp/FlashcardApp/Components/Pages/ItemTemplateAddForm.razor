@page "/itemTemplates/add"

<MudText Typo="Typo.h3" Class="mb-2">Item Template Add</MudText>

<MudStack Class="gap-4 h-full">
    <MudTextField ShrinkLabel @bind-Value="Name" Label="Name" Variant="Variant.Outlined"></MudTextField>
    <MudButton Variant=Variant.Filled Color=Color.Primary Class="w-fit" OnClick=AddCollection>Add</MudButton>
</MudStack>

@code {
    [Parameter] public string Name { get; set; } = "";

    [Inject] private ISnackbar Snackbar { get; set; }
    [Inject] private NavigationManager Navigation { get; set; }

    private async Task AddCollection()
    {
        Snackbar.Add("Item template has been added");
        Navigation.NavigateTo("/itemTemplates");
    }
}
