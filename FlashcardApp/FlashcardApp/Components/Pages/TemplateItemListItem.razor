@inherits LayoutComponentBase

<MudStack Row=true>
    <MudButton Variant="Variant.Outlined">@ChildContent</MudButton>
    <MudStack Row=true Class="gap-1">
        <MudIconButton Icon=@Icons.Material.Filled.Edit Variant=Variant.Outlined Color=Color.Primary Size=Size.Small OnClick=@OnEditButton />
        <MudIconButton Icon=@Icons.Material.Filled.ArrowUpward Variant=Variant.Outlined Color=Color.Primary Size=Size.Small OnClick=@OnEditButton />
        <MudIconButton Icon=@Icons.Material.Filled.ArrowDownward Variant=Variant.Outlined Color=Color.Primary Size=Size.Small OnClick=@OnEditButton />
        <MudIconButton Icon=@Icons.Material.Filled.Remove Variant=Variant.Outlined Color=Color.Secondary Size=Size.Small OnClick=@OnEditButton />
    </MudStack>
</MudStack>

@code {
    [Parameter] public RenderFragment ChildContent { get; set; }

    [Inject] public NavigationManager? Navigation { get; set; }

    private void OnEditButton()
    {
        //Navigation?.NavigateTo("/items/{id}/edit");
    }
}
