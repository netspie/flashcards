@page "/itemTemplates/{itemTemplateId}/flashcardTemplates/{flashcardTemplateId}/sides/{sideIndex:int}"

@using FlashcardApp.Common
@using FlashcardApp.Services

@inject ItemTemplateService ItemTemplateService

@if (_dto is null || _dtoFlashcard is null) { return; }

<MudText Typo="Typo.h5" Class="mb-2">Flashcard Template Side Fields</MudText>

<MudStack Class="gap-4">
    <EditableList 
        Items=@_dtoFlashcard.Sides[SideIndex].Fields.Select(f => (f, f)).ToList()
        OnItemAdded=OnFieldAdded
        OnItemEdit=OnFieldEdit
        OnItemMoved=OnFieldMoved
        OnItemRemoved=OnFieldRemoved />
</MudStack>

@code {
    [Parameter] public string? ItemTemplateId { get; set; }
    [Parameter] public string? FlashcardTemplateId { get; set; }
    [Parameter] public int SideIndex { get; set; }

    private Entities.ItemTemplate? _dto;
    private Entities.FlashcardTemplate? _dtoFlashcard;

    protected override async Task OnInitializedAsync() =>
        await RefreshDTO();

    private Task<bool>? OnFieldAdded(EditableList list, string field)
    {
        _dtoFlashcard.Sides[SideIndex].Fields.Add(field);
        return ItemTemplateService
            .Update(_dto)
            .Do(RefreshView);
    }

    private Task<bool>? OnFieldEdit(EditableList list, EditableListItem fielditem)
    {
        _dtoFlashcard.Sides[SideIndex].Fields[fielditem.Index] = fielditem.Name;
        return ItemTemplateService
            .Update(_dto)
            .Do(RefreshView);
    }

    private Task<bool>? OnFieldMoved(EditableList list, EditableListItem fielditem, int dir)
    {
        var f = _dtoFlashcard.Sides[SideIndex].Fields;
        var i = fielditem.Index;

        (f[i], f[i + dir]) = (f[i + dir], f[i]);
        return ItemTemplateService
            .Update(_dto)
            .Do(RefreshView);
    }

    private Task<bool>? OnFieldRemoved(EditableList list, EditableListItem fielditem)
    {
        _dtoFlashcard.Sides[SideIndex].Fields.RemoveAt(fielditem.Index);
        return ItemTemplateService
            .Update(_dto)
            .Do(RefreshView);
    }

    public async Task RefreshDTO() 
    {
        _dto = await ItemTemplateService.Get(ItemTemplateId);
        _dtoFlashcard = _dto
            .FlashcardTemplates?
            .FirstOrDefault(ft => ft.Id == FlashcardTemplateId);
    }

    public async Task RefreshView()
    {
        await RefreshDTO();
        await InvokeAsync(StateHasChanged);
    }
}
